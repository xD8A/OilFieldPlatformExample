{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NLog": {
    "throwConfigExceptions": true,
    "targets": {
      "logconsole": {
        "type": "Console",
        "layout": "${longdate}|${level:uppercase=true}|${logger}|${message}${exception:format=tostring}"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "logconsole"
      }
    ]
  },
  "Database": {
    "Provider": "Postgres",
    "Host": "localhost",
    "Port": 5432,
    "User": "calc",
    "Password": "password",
    "Name": "example",
    "Schema": "acme"
  },
  "AllowedHosts": "*",
  "StaticFiles": {
    "RootPath": "../OilFieldPlatform.Calculation.WebClient/dist"
  }
}
